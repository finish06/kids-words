{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.5.0",
  "project": {
    "name": "kids-words",
    "description": "A kids word recognition learning app for ages 4-6. Children learn words by identifying and matching images to words.",
    "created": "2026-04-04",
    "author": "calebdunn"
  },
  "maturity": {
    "level": "beta",
    "promoted_from": "alpha",
    "promoted_date": "2026-04-05",
    "next_promotion_criteria": "80%+ coverage in CI, protected branches, 30+ days stability, SLAs defined, all gates blocking, 3+ environments"
  },
  "architecture": {
    "languages": [
      {
        "name": "Python",
        "version": "3.14",
        "role": "backend"
      },
      {
        "name": "TypeScript",
        "version": "5.x",
        "role": "frontend"
      }
    ],
    "backend": {
      "framework": "FastAPI",
      "version": "latest",
      "runtime": "Python 3.14"
    },
    "frontend": {
      "framework": "React",
      "version": "19",
      "bundler": "vite"
    },
    "database": {
      "type": "TBD",
      "version": "TBD"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": false
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": null,
    "cloud_provider": "gcp",
    "cloud_services": ["Cloud Run"],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": false,
      "pipeline_file": ".github/workflows/ci.yml"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 3,
    "local": {
      "run": "docker-compose up",
      "test": "pytest",
      "e2e": "pytest tests/e2e/",
      "url": "http://localhost:8000"
    },
    "dev": {
      "deploy_trigger": "push to dev branch",
      "url": "TBD",
      "verify": ["unit_tests", "integration_tests"]
    },
    "staging": {
      "deploy_trigger": "push to staging branch",
      "url": "TBD",
      "verify": ["e2e_tests", "performance_tests"]
    },
    "production": {
      "deploy_trigger": "merge to main",
      "verify": ["smoke_tests"],
      "url": "TBD",
      "requires_approval": true
    }
  },
  "quality": {
    "mode": "standard",
    "coverage_threshold": 80,
    "type_check_blocking": true,
    "e2e_required": true,
    "screenshot_protocol": true,
    "lint": {
      "backend": "ruff check .",
      "frontend": "npm run lint"
    },
    "typecheck": {
      "backend": "mypy .",
      "frontend": "npx tsc --noEmit"
    },
    "test": {
      "unit": "pytest tests/unit/",
      "integration": "pytest tests/integration/",
      "e2e": "pytest tests/e2e/"
    }
  },
  "collaboration": {
    "autonomy_level": "autonomous",
    "team_size": "solo",
    "commit_review_gate": false,
    "pr_review_gate": false,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#6366f1",
    "presetName": "purple",
    "palette": {
      "accent": "#6366f1",
      "accentLight": "#818cf8",
      "accentDark": "#4f46e5",
      "accentMuted": "#a5b4fc",
      "accentGlow": "rgba(99,102,241,0.4)",
      "gradientStart": "#6366f1",
      "gradientMid": "#8b5cf6",
      "gradientEnd": "#d946ef",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": null,
    "tone": null,
    "logoPath": null,
    "styleGuideSource": null
  },
  "imageGeneration": {
    "enabled": false,
    "tool": null,
    "plugin": null,
    "nudged": false,
    "lastDetected": null
  },
  "changelog": {
    "lastProcessedCommit": null,
    "lastVersionTag": null
  },
  "planning": {
    "current_milestone": "M6-new-categories",
    "current_cycle": "cycle-10",
    "wip_limit": 3,
    "parallel_agents": 1,
    "cycle_history": [
      {"cycle": "cycle-9", "milestone": "M3-infrastructure-hardening", "completed": "2026-04-12", "outcome": "partial", "notes": "Items 1-3 advanced via PR #14; item 4 (v0.1.0 tag) deferred to cycle-10"}
    ]
  }
}
